/-- Partial dist function. Unvisited vertices return `none`. -/
def cert_m1_Q5_S216_dist (v : InvVertex) : Option Int :=
  (cert_m1_Q5_S216_tbl.find? (·.1 = v)).map (·.2)

/-- Start vertex. -/
def cert_m1_Q5_S216_start : InvVertex := InvStart 1

/-! ### Bool decision procedures -/

/-- Start has dist `0`. -/
def cert_m1_Q5_S216_start_check : Bool :=
  decide (cert_m1_Q5_S216_dist cert_m1_Q5_S216_start = some (0 : Int))

/-- No goal in the table has dist `< T`. -/
def cert_m1_Q5_S216_no_goal_check : Bool :=
  cert_m1_Q5_S216_tbl.all (fun ⟨v, d⟩ =>
    !(decide (v.c % (3 ^ (24 + v.j)) = 1 % (3 ^ (24 + v.j))))
    || !(decide (d < (1 : Int))))

/-- Optimistic closure check: every relevant `(s, d)` has every
outgoing edge with relevant target satisfying `dist(target) ≤ d + ω`. -/
def cert_m1_Q5_S216_closed_check : Bool :=
  cert_m1_Q5_S216_tbl.all (fun ⟨s, d⟩ =>
    let credit_s : Int := (5 : Int) - (s.j : Int)
    -- Only enforce closure on relevant labels.
    !(decide (d - credit_s < (1 : Int)))
    || (outgoingEdges 24 5 s).all (fun e =>
      let v := e.1
      let w := e.2
      let nd := d + w
      let credit_v : Int := (5 : Int) - (v.j : Int)
      -- Skip closure on non-relevant targets or oversized j.
      !(decide (v.j ≤ 5))
      || !(decide (nd - credit_v < (1 : Int)))
      || match cert_m1_Q5_S216_dist v with
         | some d' => decide (d' ≤ nd)
         | none    => false))

/-! ### Bool proofs via `native_decide` -/

theorem cert_m1_Q5_S216_start_holds :
    cert_m1_Q5_S216_start_check = true := by native_decide

theorem cert_m1_Q5_S216_no_goal_holds :
    cert_m1_Q5_S216_no_goal_check = true := by native_decide

theorem cert_m1_Q5_S216_closed_holds :
    cert_m1_Q5_S216_closed_check = true := by native_decide

/-! ### Wiring to `S216Cert` requires the adapter

With `S216CertBool_to_S216Cert` (open: see HANDOFF_S216.md §3.2):

  def cert_m1_Q5_S216 : S216Cert 24 5 (1 : Int) :=
    S216CertBool_to_S216Cert ⟨...⟩

Then `S216_barrier_for_words cert_m1_Q5_S216 (rfl) u h_q h_cyl`
closes the cylinder barrier for m=1, Q=5, T=1.
-/

